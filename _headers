/*
  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN

  # Block MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Enable XSS filter in older browsers
  X-XSS-Protection: 1; mode=block

  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — disable unused browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # - Allows Google Fonts (stylesheet + fonts)
  # - Allows the logo image from ibb.co
  # - Allows inline styles and scripts (required for single-file app)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://i.ibb.co; connect-src 'self'; frame-ancestors 'none';

  # Cache static assets aggressively
  Cache-Control: public, max-age=3600, must-revalidate

/*.html
  # HTML — shorter cache so updates go live quickly
  Cache-Control: public, max-age=0, must-revalidate
